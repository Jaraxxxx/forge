{
  "name": "forge",
  "version": "0.1.0",
  "description": "AI-first coding agent harness — model-agnostic, context-intelligent, self-improving",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "forge": "./bin/forge.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "format": "biome format --write src/"
  },
  "keywords": ["ai", "agent", "claude-code", "pi", "codex", "coding-agent"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.0.0",
    "@biomejs/biome": "^1.9.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "openai": "^5.0.0",
    "@google/generative-ai": "^0.24.0",
    "terminal-kit": "^3.1.0",
    "better-sqlite3": "^11.0.0",
    "jiti": "^2.0.0"
  }
}